# ── Core ───────────────────────────────────────────────────────────────────
# Public-facing URL used in share links and doc URLs printed to terminal.
# Omit or set to localhost:8080 for a local-only setup.
DOC_HOST=localhost             # or your public hostname
DOC_PORT=8080                  # public port (as seen by the browser)
DOC_SCHEME=http                # http for localhost, https for public
# Internal bind config — set COHERENCE_PORT=8081 and COHERENCE_BIND=127.0.0.1
# when running behind nginx; leave defaults (8080, 0.0.0.0) for standalone.
COHERENCE_PORT=8080
COHERENCE_BIND=0.0.0.0

# ── Doc data dir (optional) ────────────────────────────────────────────────
# DOC_DATA_DIR=~/.coherence/data   # override default doc store path

# ── GitHub (optional) ──────────────────────────────────────────────────────
GITHUB_ORG=                   # e.g. myorg — enables pretty PR URL labels in docs

# ── Jira (optional) ────────────────────────────────────────────────────────
JIRA_BASE_URL=                # e.g. https://myorg.atlassian.net — enables bare ticket ID auto-linking in docs

# ── Footer text (optional) ─────────────────────────────────────────────────
# FOOTER_TEXT=Built with coherence   # shown in all page footers (default: "Built with coherence")

# ── suggest-compact hook (optional) ────────────────────────────────────────
# COMPACT_THRESHOLD=50         # suggest /compact after N tool calls (default: 50)

# ── User identity via auth proxy (optional) ────────────────────────────────
# Set REMOTE_USER_HEADER to the header your auth proxy injects with the user's email.
# Falls back to "anonymous" if the header is absent (full open access preserved).
# REMOTE_USER_HEADER=X-Remote-User

# If your proxy sends a JWT instead of a plain email (e.g. AWS ALB x-amzn-oidc-data):
# REMOTE_USER_JWT_HEADER=X-Remote-User-JWT

# Restrict portal access to specific users or a domain (optional).
# Share links (?share=token) always bypass this check.
# ALLOWED_USERS=alice@org.com,bob@org.com
# ALLOWED_DOMAIN=org.com

# Allow any authenticated user read-only access when ALLOWED_USERS/ALLOWED_DOMAIN is set.
# Guests see docs but cannot add comments, share, or edit. Only allowed users get write access.
# GUEST_ACCESS=true
