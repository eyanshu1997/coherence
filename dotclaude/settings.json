{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__",
        "hooks": [
          {
            "type": "command",
            "command": "${COHERENCE_HOME:-$HOME/coherence}/bin/coherence-mcp-log"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${COHERENCE_HOME:-$HOME/coherence}/bin/coherence-bash-log"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${COHERENCE_HOME:-$HOME/coherence}/scripts/hooks/suggest-compact.js\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); cwd=$(echo \"$input\" | jq -r '.cwd'); branch=$(git -C \"$cwd\" --no-optional-locks rev-parse --abbrev-ref HEAD 2>/dev/null); [ -n \"$branch\" ] && printf ' %s' \"$branch\""
  }
}
